# Database Configuration
# Replace with your actual PostgreSQL credentials
DATABASE_URL="postgresql://username:password@localhost:5432/smart_db"

# JWT Secret Key
# Generate a secure random string for production
JWT_SECRET="your-secret-key-here-change-in-production"

# Server Port
PORT=5003

# External System Base URLs (read-only integrations)
# Used by Admin System Monitor reachability pings
ENROLLPRO_URL="http://localhost:5002/api/health"
ATLAS_URL="http://localhost:5001/api/v1/health"
AIMS_URL="http://localhost:5000/api/v1/health"
