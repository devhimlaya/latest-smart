// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TEACHER
  ADMIN
  REGISTRAR
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
}

enum GradeLevel {
  GRADE_7
  GRADE_8
  GRADE_9
  GRADE_10
}

enum SubjectType {
  CORE           // 30% WW, 50% PT, 20% QA (English, Math, Science, Filipino, AP)
  PE_HEALTH      // 20% WW, 60% PT, 20% QA
  MAPEH          // Computed as average of Music, Arts, PE, Health
  TLE            // 20% WW, 60% PT, 20% QA
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      Role
  firstName String?
  lastName  String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teacher   Teacher?
}

model Teacher {
  id               String            @id @default(cuid())
  userId           String            @unique
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId       String            @unique
  specialization   String?
  classAssignments ClassAssignment[]
  advisorySections Section[]         @relation("SectionAdviser")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Student {
  id           String       @id @default(cuid())
  lrn          String       @unique // Learner Reference Number
  firstName    String
  middleName   String?
  lastName     String
  suffix       String?      // Jr., III, etc.
  birthDate    DateTime?
  gender       String?
  address      String?
  guardianName String?
  guardianContact String?
  enrollments  Enrollment[]
  grades       Grade[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Section {
  id          String       @id @default(cuid())
  name        String       // e.g., "Einstein", "Newton"
  gradeLevel  GradeLevel
  schoolYear  String       // e.g., "2025-2026"
  adviserId   String?      // Reference to Teacher
  adviser     Teacher?     @relation("SectionAdviser", fields: [adviserId], references: [id])
  enrollments Enrollment[]
  classAssignments ClassAssignment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([name, gradeLevel, schoolYear])
}

model Subject {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String            // e.g., "English", "Mathematics", "Science"
  description      String?
  type             SubjectType       @default(CORE)
  writtenWorkWeight Int              @default(30)  // percentage
  perfTaskWeight   Int               @default(50)  // percentage
  quarterlyAssessWeight Int          @default(20)  // percentage
  classAssignments ClassAssignment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model ClassAssignment {
  id         String   @id @default(cuid())
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sectionId  String
  section    Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  schoolYear String   // e.g., "2025-2026"
  grades     Grade[]
  
  // ECR (E-Class Record) import tracking
  ecrLastSyncedAt DateTime?  // Last ECR sync timestamp
  ecrFileName     String?    // Original ECR filename for reference
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([teacherId, subjectId, sectionId, schoolYear])
}

model Enrollment {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sectionId  String
  section    Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  schoolYear String   // e.g., "2025-2026"
  status     String   @default("ENROLLED") // ENROLLED, TRANSFERRED, DROPPED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([studentId, sectionId, schoolYear])
}

model Grade {
  id                String          @id @default(cuid())
  studentId         String
  student           Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classAssignmentId String
  classAssignment   ClassAssignment @relation(fields: [classAssignmentId], references: [id], onDelete: Cascade)
  quarter           Quarter

  // Written Work scores (multiple activities)
  writtenWorkScores Json?    // Array of { name: string, score: number, maxScore: number }
  
  // Performance Task scores (multiple activities)
  perfTaskScores    Json?    // Array of { name: string, score: number, maxScore: number }
  
  // Quarterly Assessment (usually one exam)
  quarterlyAssessScore Float?
  quarterlyAssessMax   Float?  @default(100)

  // Computed grades (stored for performance)
  writtenWorkPS     Float?   // Percentage Score
  perfTaskPS        Float?   // Percentage Score
  quarterlyAssessPS Float?   // Percentage Score
  initialGrade      Float?   // Sum of weighted scores
  quarterlyGrade    Float?   // Transmuted grade

  remarks           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([studentId, classAssignmentId, quarter])
}

// Audit Log for tracking all system activities
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  CONFIG
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

model AuditLog {
  id          String        @id @default(cuid())
  action      AuditAction
  userId      String?       // User who performed the action (null for system actions)
  userName    String        // Cached user name for display
  userRole    String        // Cached user role
  target      String        // What was affected (e.g., "Student Grades", "User Account")
  targetType  String        // Category (e.g., "Grades", "Auth", "Config", "Student", "User")
  targetId    String?       // ID of the affected entity if applicable
  details     String        // Human-readable description
  ipAddress   String?       // IP address of the request
  severity    AuditSeverity @default(INFO)
  metadata    Json?         // Additional data as JSON
  createdAt   DateTime      @default(now())
  
  @@index([createdAt])
  @@index([userId])
  @@index([action])
  @@index([targetType])
}

// System Settings for school configuration
model SystemSettings {
  id                String   @id @default("main") // Single row with fixed ID
  schoolName        String   @default("Sample High School")
  schoolId          String   @default("123456")
  division          String   @default("Division of Sample City")
  region            String   @default("Region IV-A CALABARZON")
  address           String?
  contactNumber     String?
  email             String?
  
  // Academic Settings
  currentSchoolYear String   @default("2025-2026")
  currentQuarter    Quarter  @default(Q1)
  
  // Academic Calendar - Quarter Start/End Dates
  q1StartDate       DateTime?
  q1EndDate         DateTime?
  q2StartDate       DateTime?
  q2EndDate         DateTime?
  q3StartDate       DateTime?
  q3EndDate         DateTime?
  q4StartDate       DateTime?
  q4EndDate         DateTime?
  autoAdvanceQuarter Boolean @default(false)  // Auto-advance quarter when end date is reached
  
  // Theming - Logo and Color Scheme
  logoUrl           String?  // Path to uploaded logo
  primaryColor      String   @default("#6366f1")   // Indigo-500
  secondaryColor    String   @default("#8b5cf6")   // Violet-500
  accentColor       String   @default("#06b6d4")   // Cyan-500
  
  // System Config
  sessionTimeout    Int      @default(30)          // minutes
  maxLoginAttempts  Int      @default(5)
  passwordMinLength Int      @default(8)
  requireSpecialChar Boolean @default(true)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Grading Configuration per subject type
model GradingConfig {
  id                    String      @id @default(cuid())
  subjectType           SubjectType @unique
  writtenWorkWeight     Int         // percentage
  performanceTaskWeight Int         // percentage
  quarterlyAssessWeight Int         // percentage
  isDepEdDefault        Boolean     @default(true)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}
