  type SubjectType
  writtenWorkWeight int [default: 30]
  perfTaskWeight int [default: 50]
  quarterlyAssessWeight int [default: 20]
  createdAt timestamp
  updatedAt timestamp [not null]
}
Table ClassAssignment {
  id varchar [pk]
