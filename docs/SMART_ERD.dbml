  updatedAt timestamp [not null]

  indexes {
    (studentId, sectionId, schoolYear) [unique]
    (schoolYear, status)
    (sectionId, schoolYear, status)
    (studentId, schoolYear)
  }
}
Table Grade {
  id varchar [pk]
  studentId varchar [not null]
  classAssignmentId varchar [not null]
