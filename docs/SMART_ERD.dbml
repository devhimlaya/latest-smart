  SF4
  SF5
  SF6
  SF8
  SF9
  SF10
  SF7
}

Table User {
  id varchar [pk]
  username varchar [not null, unique]
  password varchar [not null]
  role Role [not null]
  firstName varchar
  lastName varchar
  email varchar
  createdAt timestamp
  updatedAt timestamp [not null]
}
Table Teacher {
  id varchar [pk]
  userId varchar [not null, unique]
  employeeId varchar [not null, unique]
  specialization varchar
  createdAt timestamp
  updatedAt timestamp [not null]
}
Table Student {
  id varchar [pk]
  lrn varchar [not null, unique]
  firstName varchar [not null]
  middleName varchar
  lastName varchar [not null]
  suffix varchar
  birthDate timestamp
  gender varchar
  address varchar
  guardianName varchar
  guardianContact varchar
  createdAt timestamp
  updatedAt timestamp [not null]

  indexes {
    (lastName, firstName)
  }
}
Table Section {
  id varchar [pk]
  name varchar [not null]
